# WordPress Core & Configuration
/wp-admin/
/wp-content/index.php
/wp-content/languages/
/wp-content/plugins/index.php
/wp-content/themes/index.php
/wp-includes/
/index.php
/license.txt
/readme.html
/wp-*.php
/xmlrpc.php
wp-config.php
/.htaccess
*.log

# Uploads & Plugins
/wp-content/uploads/
/wp-content/plugins/

# Ignore ALL themes EXCEPT your custom theme
/wp-content/themes/*
!/wp-content/themes/rabbit_school/
!/wp-content/themes/rabbit_school/**

# Safety rules for accidental WP copies inside theme
/wp-content/themes/rabbit_school/wp-*.php
/wp-content/themes/rabbit_school/wp-admin/
/wp-content/themes/rabbit_school/wp-includes/

# Node & OS Ignores
**/node_modules/
.npm/
npm-debug.log*
**/.DS_Store
Thumbs.db

# Style.css Rules
**/style.css
!/wp-content/themes/rabbit_school/style.css