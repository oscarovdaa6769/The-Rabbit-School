# Ignore all uploads
wp-content/uploads/

# Ignore ALL plugins 
wp-content/plugins/

# Ignore ALL themes EXCEPT your custom theme
wp-content/themes/*
!wp-content/themes/rabbit_school/

# Tailwind & Node.js Ignores
**/node_modules/
**/package-lock.json
**/.DS_Store