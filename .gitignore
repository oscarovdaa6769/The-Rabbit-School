# WordPress Core Ignores
/wp-admin/
/wp-includes/
/wp-*.php
/index.php
/license.txt
/readme.html
/xmlrpc.php
/wp-config.php
/.htaccess
*.log

# Ignore Content, Uploads & Plugins
/wp-content/uploads/
/wp-content/plugins/
/wp-content/languages/
/wp-content/index.php

# Ignore ALL themes EXCEPT your custom theme
/wp-content/themes/*
!/wp-content/themes/rabbit_school/
!/wp-content/themes/rabbit_school/**

# Ignore compiled Tailwind style.css to prevent merge conflicts
/wp-content/themes/rabbit_school/style.css

# Node & OS Ignores
**/node_modules/
.npm/
npm-debug.log*
**/.DS_Store
Thumbs.db